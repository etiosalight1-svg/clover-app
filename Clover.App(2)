  if(userProfile)userProfile.name=v.trim();
  document.getElementById('prof-name').textContent=v.trim();
  document.getElementById('home-name').textContent=v.trim().split(' ')[0];
  document.getElementById('side-name').textContent=v.trim();
  try{await db.collection('users').doc(currentUser.uid).update({name:v.trim()});}catch(e){}
}
function setTheme(color,el){
  document.documentElement.style.setProperty('--bg',color);
  document.querySelectorAll('.sw').forEach(s=>s.classList.remove('on'));el.classList.add('on');
}
function tog(el){el.classList.toggle('on');}

/* UTILS */
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200);}
function timeAgo(date){
  if(!date)return 'Just now';
  const s=Math.floor((Date.now()-date.getTime())/1000);
  if(s<10)return 'Just now';if(s<60)return s+'s ago';if(s<3600)return Math.floor(s/60)+'m ago';
  if(s<86400)return Math.floor(s/3600)+'h ago';return Math.floor(s/86400)+'d ago';
}

/* TICKER */
const ticks=['<strong>Sports Arena</strong> · Football — 2 live matches now','<strong>Tech Hub</strong> · Crypto — Bitcoin up 3.2% today','<strong>Planet Pulse</strong> · Climate — New report trending','<strong>Social Sphere</strong> · Global News trending','<strong>Sciences</strong> · Space — Webb telescope update'];
let tickIdx=0;
function rotateTicker(){tickIdx=(tickIdx+1)%ticks.length;const el=document.getElementById('ticker-text');if(el)el.innerHTML=ticks[tickIdx];}
setInterval(rotateTicker,4000);
function showPostMenu(docId, postUserId){
  const isAdmin = currentUser?.email === ADMIN_EMAIL;
  const isOwner = currentUser?.uid === postUserId;
  const options = [];
  if(isAdmin || isOwner){
    options.push({label:'🗑️ Delete post', action:()=>deletePost(docId)});
  }
  options.push({label:'🚩 Report post', action:()=>reportPost(docId)});
  const sheet = document.createElement('div');
  sheet.style.cssText='position:fixed;inset:0;z-index:99999;display:flex;flex-direction:column;justify-content:flex-end;background:rgba(0,0,0,.5)';
  const menu = document.createElement('div');
  menu.style.cssText='background:#1a1a22;border-radius:20px 20px 0 0;padding:16px;display:flex;flex-direction:column;gap:8px;';
  options.forEach(opt=>{
    const btn=document.createElement('button');
    btn.style.cssText='padding:16px;border:none;background:#2a2a35;color:#f0f0f8;border-radius:12px;font-size:15px;font-family:Space Grotesk,sans-serif;cursor:pointer;text-align:left;';
    btn.textContent=opt.label;
    btn.onclick=()=>{document.body.removeChild(sheet);opt.action();};
    menu.appendChild(btn);
  });
  const cancel=document.createElement('button');
  cancel.style.cssText='padding:16px;border:none;background:#2a2a35;color:#f04060;border-radius:12px;font-size:15px;font-family:Space Grotesk,sans-serif;cursor:pointer;margin-top:4px;';
  cancel.textContent='Cancel';
  cancel.onclick=()=>document.body.removeChild(sheet);
  menu.appendChild(cancel);
  sheet.appendChild(menu);
  sheet.onclick=(e)=>{if(e.target===sheet)document.body.removeChild(sheet);};
  document.body.appendChild(sheet);
}

async function deletePost(docId){
  if(!db||!currentUser)return;
  try{
    await db.collection('posts').doc(docId).delete();
    const el=document.getElementById('post-'+docId);
    if(el)el.remove();
    showToast('Post deleted');
  }catch(e){showToast('Could not delete post');}
}

async function reportPost(docId){
  if(!db||!currentUser)return;
  try{
    await db.collection('reports').add({
      postId:docId,
      reportedBy:currentUser.uid,
      reportedAt:firebase.firestore.FieldValue.serverTimestamp(),
      pillarId:curPillar,
      subId:curSub
    });
    showToast('Post reported — we will review it 🚩');
  }catch(e){showToast('Could not report post');}
}
</script>
