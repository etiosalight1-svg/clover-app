async function likePost(docId){
  if(!FIREBASE_READY||!db||!currentUser){
    const el=document.getElementById('like-'+docId);
    if(el)el.classList.toggle('liked');
    return;
  }
  const ref=db.collection('posts').doc(docId);
  const snap=await ref.get();if(!snap.exists)return;
  const data=snap.data();
  const liked=data.likedBy?.includes(currentUser.uid);
  ref.update({likes:firebase.firestore.FieldValue.increment(liked?-1:1),likedBy:liked?firebase.firestore.FieldValue.arrayRemove(currentUser.uid):firebase.firestore.FieldValue.arrayUnion(currentUser.uid)});
  const el=document.getElementById('like-'+docId);
  const lc=document.getElementById('lc-'+docId);
  if(el)el.classList.toggle('liked',!liked);
  if(lc)lc.textContent=(data.likes||0)+(liked?-1:1);
}

function replyPost(docId){
  const rw=document.getElementById('rw-'+docId);if(!rw)return;
  const open=rw.classList.contains('show');
  document.querySelectorAll('.reply-wrap').forEach(r=>r.classList.remove('show'));
  if(!open){rw.classList.add('show');rw.querySelector('textarea').focus();}
}

async function sendReply(docId){
  const inp=document.getElementById('ri-'+docId);
  const txt=inp.value.trim();if(!txt||!currentUser||!userProfile)return;
  await db.collection('posts').add({pillarId:curPillar,subId:curSub,userId:currentUser.uid,userHandle:userProfile.handle,userName:userProfile.name,userPic:userProfile.pic||'',bot:false,verified:false,text:'↩ '+txt,likes:0,likedBy:[],replyTo:docId,createdAt:firebase.firestore.FieldValue.serverTimestamp()});
  inp.value='';document.getElementById('rw-'+docId).classList.remove('show');
}

