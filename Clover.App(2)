function listenFeed(pid,sid){
  if(feedUnsub){feedUnsub();feedUnsub=null;}
  const c=document.getElementById('feed-posts');
  if(!FIREBASE_READY||!db){
    c.innerHTML='';
    const p=PILLARS.find(x=>x.id===pid);
    renderPost('demo-1',{pillarId:pid,subId:sid,userId:'bot',userHandle:'@CloverBot',userName:'CloverBot',userPic:'',bot:true,verified:true,text:`Welcome to <strong>${curSubLabel}</strong>! Share ideas, ask questions, and connect with people who share your passion. 🍀`,likes:18,likedBy:[],createdAt:null});
    renderPost('demo-2',{pillarId:pid,subId:sid,userId:'u2',userHandle:'@Alex_K',userName:'Alex K',userPic:'',bot:false,verified:false,text:'Just joined this community! Really excited to connect with everyone here. Who else is active? 👋',likes:7,likedBy:[],createdAt:null});
    renderPost('demo-3',{pillarId:pid,subId:sid,userId:'u3',userHandle:'@Maria_V',userName:'Maria V',userPic:'',bot:false,verified:true,text:'Quick tip: use the reply button to respond to posts, and the message button to DM someone privately. 💬',likes:22,likedBy:[],createdAt:null});
    return;
  }
  c.innerHTML='<div class="no-posts">Loading…</div>';
  const ref=db.collection('posts').where('pillarId','==',pid).where('subId','==',sid).orderBy('createdAt','asc').limit(50);
  feedUnsub=ref.onSnapshot(async snap=>{
    if(snap.empty){
      await db.collection('posts').add({pillarId:pid,subId:sid,userId:'bot',userHandle:'@CloverBot',userName:'CloverBot',userPic:'',bot:true,verified:true,text:`Welcome to <strong>${curSubLabel}</strong>! Share ideas, ask questions, and connect with people who share your passion. 🍀`,likes:0,likedBy:[],createdAt:firebase.firestore.FieldValue.serverTimestamp()});
      return;
    }
    c.innerHTML='';
    snap.forEach(doc=>renderPost(doc.id,doc.data()));
  },err=>{
    if(err.code==='failed-precondition')c.innerHTML='<div class="no-posts">Set up Firestore index in Firebase Console → Firestore → Indexes.<br><br>Add: posts | pillarId ASC, subId ASC, createdAt ASC</div>';
    else c.innerHTML='<div class="no-posts">Could not load posts. Check your Firebase config.</div>';
