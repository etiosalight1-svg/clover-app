function closeDM(){document.getElementById('dm').classList.remove('show');}

function renderDM(username,pic){
  const c=document.getElementById('dm-msgs');c.innerHTML='';
  const color=document.getElementById('dm-send').style.background;
  const uSVG=`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px;stroke:var(--muted)"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`;
  (dmConvos[username]||[]).forEach(msg=>{
    const d=document.createElement('div');d.className='dm-msg'+(msg.mine?' mine':'');
    const myAv=userProfile?.pic?`<img src="${userProfile.pic}"/>`:uSVG;
    const theirAv=pic?`<img src="${pic}"/>`:uSVG;
    const bs=msg.mine?`style="background:${color};"`:'';
    d.innerHTML=`${!msg.mine?`<div class="dm-msg-av">${theirAv}</div>`:''}<div><div class="dm-bubble" ${bs}>${msg.text}</div><div class="dm-t">${timeAgo(msg.time)}</div></div>${msg.mine?`<div class="dm-msg-av">${myAv}</div>`:''}`;
    c.appendChild(d);
  });
  c.scrollTop=c.scrollHeight;
}

function sendDM(){
  const inp=document.getElementById('dm-in');
  const txt=inp.value.trim();if(!txt)return;
  const uname=document.getElementById('dm-uname').textContent;
  const pic=document.getElementById('dm-av').querySelector('img')?.src||'';
  if(!dmConvos[uname])dmConvos[uname]=[];
  dmConvos[uname].push({mine:true,text:txt,time:new Date()});
  inp.value='';renderDM(uname,pic);
  setTimeout(()=>{
    const r=["Got it! Thanks 🙌","Interesting! Tell me more 👀","Love the energy 🔥","Let's connect!","Great point! 💯"];
    dmConvos[uname].push({mine:false,text:r[Math.floor(Math.random()*r.length)],time:new Date()});
    renderDM(uname,pic);
  },900);
}
function dmKey(e){if(e.key==='Enter'&&!e.shiftkey){e.preventDefault();sendDM();}} 
/* PULSE */
function loadPulse(){
  const list=document.getElementById('pulse-list');
  if(!FIREBASE_READY||!db){
    list.innerHTML='<div class="no-posts">Connect Firebase to see live activity.</div>';
    document.getElementById('pulse-count').textContent='Demo mode';
    return;
  }
  list.innerHTML='<div class="no-posts">Loading activity…</div>';
  if(pulseUnsub)pulseUnsub();
  pulseUnsub=db.collection('posts').orderBy('createdAt','desc').limit(30).onSnapshot(snap=>{
    list.innerHTML='';let count=0;
    snap.forEach(doc=>{
      const post=doc.data();if(post.bot)return;
      const p=PILLARS.find(x=>x.id===post.pillarId);if(!p)return;
      const sub=p.subs.find(s=>s.id===post.subId);
      count++;
      const d=document.createElement('div');d.className='pi fu';
      d.innerHTML=`<div class="pi-thumb" style="background-image:url('${sub?.img||p.img}')"></div><div class="pi-body"><div class="pi-meta"><div class="pi-dot" style="background:${p.color}"></div><span class="pi-user">${post.userHandle||post.userName}</span></div><div class="pi-text">Posted in ${p.title} · ${sub?.l||''}</div><div class="pi-time">${timeAgo(post.createdAt?.toDate?.()||new Date())}</div></div>`;
      list.appendChild(d);
    });
    document.getElementById('pulse-count').textContent=count+' active';
    if(count===0)list.innerHTML='<div class="no-posts">No activity yet — be the first to post!</div>';
  },()=>{list.innerHTML='<div class="no-posts">Could not load pulse.</div>';});
}
